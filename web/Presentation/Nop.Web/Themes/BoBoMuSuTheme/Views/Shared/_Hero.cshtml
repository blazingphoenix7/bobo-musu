@if (Context.Request.Path == "/")
{
    <div id="mainCarousel">
        <img src="~/Themes/BoBoMuSuTheme/Content/images/bm/home1.png?pr=1" width="150%">
    </div>
}
else if (Context.Request.Path == "/shop")
{
    <div id="mainCarousel">
        <img src="~/Themes/BoBoMuSuTheme/Content/images/bm/home2.png?pr=1" width="150%">
    </div>
}