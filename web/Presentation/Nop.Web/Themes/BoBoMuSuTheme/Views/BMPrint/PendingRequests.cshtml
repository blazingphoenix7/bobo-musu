@using System.Text.Encodings.Web
@using Nop.Core
@using Nop.Web.Models.BM
@model RequestListModel
@inject Nop.Core.IWebHelper webHelper
@{
    Layout = "_ColumnsTwo";

    //title
    Html.AddTitleParts(T("PageTitle.Account").Text);
    Html.AppendPageCssClassParts("print-vault");
}
@section left
{
    @await Component.InvokeAsync("BMPrintVaultNavigation", new { selectedTabId = PrintVaultNavigationEnum.PendingRequests })
}

<div class="page account-page pending-request-panel from-panel">
    <div class="page-title panel-heading element-fixed">
        <h1>Pending Requests</h1>
    </div>
    <div class="page-body panel-body element-scroll">
        @if (!Model.Requests.Any())
        {
            <div class="no-data">
                No data
            </div>
        }
        @foreach (var item in Model.Requests)
        {
            <div class="pending-request-item">
                <div class="row">
                    <div class="col-sm-9 col-md-9 col-xs-12">
                        <div class="request-sender">@item.ToCustomerName</div>
                        <div>@item.Message</div>
                    </div>
                    <div class="col-sm-3 col-md-3 col-xs-12">
                        <div class="pull-right">
                            <button type="button"
                                    class="btn btn-sm btn-default btn-delete-pending-request"
                                    data-request-id="@item.RequestId">
                                <span class="glyphicon glyphicon-remove" aria-hidden="true"></span>
                            </button>
                            <a href="/print/pendinglist/accept/@item.RequestId/@item.ToCustomerId"
                               class="btn btn-sm btn-primary-custom btn-accept-pending-request">
                                ACCEPT
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
    <div class="row panel-footer element-fixed">
        <div class="col-xs-12 col-md-12 col-sm-12 text-center">
            <a href="@Url.RouteUrl("BMMessages")" class="btn btn-primary-custom">Messages</a>
        </div>
    </div>
</div>

<form asp-route="BMPendingRequests_Delete" class="form-horizontal" method="post">
    <div id="delete-pending-request-modal" class="modal fade" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                    <h4 class="modal-title">Confirmation</h4>
                </div>
                <div class="modal-body">
                    <p>Are you sure delete this item?</p>
                </div>
                <div class="modal-footer">
                    <input type="hidden" id="deleteRequestId" name="requestId"/>
                    <button type="submit" class="btn btn-primary-custom">YES</button>
                    <button type="button" class="btn btn-default" data-dismiss="modal">NO</button>
                </div>
            </div>
        </div>
    </div>
</form>

<script asp-location="Footer">
    $('.btn-delete-pending-request').click(function () {
        var requestId = $(this).data('request-id');
        $('#deleteRequestId').val(requestId);
        $('#delete-pending-request-modal').modal();
    });
</script>