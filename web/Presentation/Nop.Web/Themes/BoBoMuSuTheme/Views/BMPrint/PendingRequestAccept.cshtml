@using System.Text.Encodings.Web
@using Nop.Core
@using Nop.Web.Models.BM
@model RequestModel
@inject Nop.Core.IWebHelper webHelper
@{
    Layout = "_ColumnsTwo";

    //title
    Html.AddTitleParts(T("PageTitle.Account").Text);
}
@section left
{
    @await Component.InvokeAsync("BMPrintVaultNavigation", new { selectedTabId = PrintVaultNavigationEnum.PendingRequests })
}
<form asp-route="BMPendingRequests_Accept" class="form-horizontal" method="post">
    <div class="page account-page pending-request-accept-panel from-panel">
        <div class="page-body panel-body element-scroll">
            <div class="form-group">
                <div class="col-sm-10 col-md-10 col-xs-12">
                    <input type="text" class="form-control" id="title" asp-for="Title" placeholder="@Html.DisplayNameFor(m=>m.Title)" />
                </div>
                <div class="col-sm-2 col-md-2 col-xs-1">
                    <nop-required />
                </div>
            </div>
            <div class="form-group">
                <div class="col-sm-10 col-md-10 col-xs-12">
                    <textarea rows="10" class="form-control" id="message" asp-for="Message" placeholder="@Html.DisplayNameFor(m=>m.Message)"></textarea>
                </div>
                <div class="col-sm-2 col-md-2 col-xs-1">
                    <nop-required />
                </div>
            </div>
            <div class="form-group">
                <div class="col-sm-10 col-md-10 col-xs-12">
                    <button type="button" class="btn btn-primary-custom btn-sm btn-add-new-print">Take a Print</button>
                </div>
                <div class="col-sm-1 col-md-1 col-xs-1">
                </div>
            </div>
            <div class="form-group">
                <div class="col-sm-10 col-md-10 col-xs-12">
                    <select class="form-control dropdown-toggle select-print-share" asp-for="SharedPrintId">
                        <option selected="selected" value="">Select a PRINT</option>
                        @foreach (var item in Model.MyPrints)
                        {
                            <option value="@item.Id" data-thumbnail-path="@item.ThumbnailPath">@item.Name</option>
                        }
                    </select>
                </div>
                <div class="col-sm-2 col-md-2 col-xs-1">
                    <nop-required />
                </div>
            </div>
        </div>
        <div class="row panel-footer element-fixed">
            <div class="col-xs-12 col-md-12 col-sm-12 text-center">
                <input type="hidden" id="requestId" asp-for="RequestId" value="@Model.RequestId"/>
                <input type="hidden" id="toCustomerId" asp-for="ToCustomerId" value="@Model.ToCustomerId"/>
                <button type="submit" class="btn btn-primary-custom">SUBMIT</button>
                <a href="/print/messagelist" class="btn btn-default">CANCEL</a>
            </div>
        </div>
    </div>
</form>
<script asp-location="Footer">
    $('.select-print-share').change(function () {
        var thumbPath = $(".select-print-share option:selected").data('thumbnail-path');
        if (thumbPath) {
            $('.my-print-icon').attr('src', thumbPath);
            $('.view-select-print-share').removeClass('hide');
        } else {
            $('.view-select-print-share').addClass('hide');
        }
    });
    $('.btn-add-new-print').click(function () {
        bm.addNewPrint();
    });
</script>