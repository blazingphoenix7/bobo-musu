@model PasswordRecoveryModel
@{
    Layout = Context.Request.IsMobileBrowser() ? "_BMLayout" : "_ColumnsOne";

    //title
    Html.AddTitleParts(T("PageTitle.PasswordRecovery").Text);
    //page class
    Html.AppendPageCssClassParts("html-password-recovery-page");
}
<div class="page password-recovery-page from-panel">
    <div class="page-title panel-heading">
        @if (Context.Request.IsMobileBrowser())
        {
            <a href="javascript:void(0);" class="back-prev-page-link"><i class="glyphicon glyphicon-home glyphicon-menu-left back-prev-icon"></i></a>
        }
        <h1>@T("Account.PasswordRecovery")</h1>
    </div>
    <div class="page-body panel-body">
        <form asp-route="PasswordRecovery" method="post">
            <div asp-validation-summary="ModelOnly" class="message-error"></div>
            <div class="description alert alert-info">@T("Account.PasswordRecovery.Tooltip")</div>
            <div class="form-horizontal" role="form">
                <div class="form-group row">
                    @*<label class="control-label col-sm-4 col-md-5 col-xs-12 password-text" asp-for="Email" asp-postfix=":"></label>*@
                    <div class="col-sm-offset-4 col-md-offset-5 col-sm-5 col-md-3 col-xs-12">
                        <input asp-for="Email" class="email form-control" placeholder="@Html.DisplayNameFor(m=>m.Email)" />
                    </div>
                    <div class="col-sm-3 col-md-4 col-xs-12">
                        <nop-required />
                        <span asp-validation-for="Email"></span>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-offset-4 col-md-offset-5 col-sm-5 col-md-5">
                        <input type="submit" name="send-email" class="btn btn-primary-custom password-recovery-button" value="@T("Account.PasswordRecovery.RecoverButton")" />
                        &nbsp;&nbsp;<a href="/login">Login</a>
                    </div>
                </div>
            </div>
        </form>
        @if (!string.IsNullOrEmpty(Model.Result))
        {
            <div class="alert alert-info">
                @Model.Result
            </div>
            if (ViewBag.IsSuccess != null && Convert.ToBoolean(ViewBag.IsSuccess))
            {
                <script type="text/javascript">
                    setTimeout(function() {
                        window.location.href = "/login";
                    }, 2000);
                </script>
            }
        }
    </div>
</div>
