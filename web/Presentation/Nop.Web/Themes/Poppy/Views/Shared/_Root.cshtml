@using Microsoft.AspNetCore.Mvc;
@using Nop.Web.Extensions;
@using Microsoft.AspNetCore.Http
@using Nop.Core.Common

@inject IHttpContextAccessor httpAccesor
@{
  Layout = "_Root.Head";
  bool isProductDetailPage = ViewData[ViewDataKey.IS_PRODUCT_DETAIL_PAGE] == null ? false : (bool)ViewData[ViewDataKey.IS_PRODUCT_DETAIL_PAGE];
  bool applyBack = ViewData[ViewDataKey.APPLY_BACK] == null ? false : (bool)ViewData[ViewDataKey.APPLY_BACK];
  string backAction = ViewData[ViewDataKey.BACK_ACTION] == null ? string.Empty : ViewData[ViewDataKey.BACK_ACTION].ToString();
  string backIconClass = ViewData[ViewDataKey.BACK_ICON_CLASS] == null ? string.Empty : ViewData[ViewDataKey.BACK_ICON_CLASS].ToString();
  bool showGoToTop = ViewData[ViewDataKey.SHOW_GO_TO_TOP] == null ? false : (bool)ViewData[ViewDataKey.SHOW_GO_TO_TOP];
  bool showFingerBackground = ViewData[ViewDataKey.SHOW_FINGER_BACKGROUND] == null ? false : (bool)ViewData[ViewDataKey.SHOW_FINGER_BACKGROUND];
  bool showLeaveConfirmation = ViewData[ViewDataKey.SHOW_LEAVE_CONFIRMATION] == null ? false : (bool)ViewData[ViewDataKey.SHOW_LEAVE_CONFIRMATION];
}
@{
  var controllerName = Url.ActionContext.RouteData.Values["controller"].ToString();
  var isHomePage = controllerName.Equals("home", StringComparison.InvariantCultureIgnoreCase);
  bool isMobile = httpAccesor.HttpContext.Request.IsMobileBrowser();
}

@await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.BodyStartHtmlTagAfter })
@await Html.PartialAsync("_Notifications")
@await Html.PartialAsync("_JavaScriptDisabledWarning")
@await Html.PartialAsync("_OldInternetExplorerWarning")
@await Component.InvokeAsync("AdminHeaderLinks")
@section viewPort{
  @if (isMobile)
  {
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1" />
  }
  else
  {
    <meta name="viewport" content="width=device-width, height=device-height, initial-scale=1, maximum-scale=1, user-scalable=no, target-densitydpi=device-dpi" />
    <meta name='apple-mobile-web-app-capable' content='yes' />
    <meta name='apple-mobile-web-app-status-bar-style' content='black-translucent' />
    <style>
      body {
        touch-action: manipulation !important;
      }
    </style>
  }
}
@section AboveCss{
  @RenderSection("AboveCss", false)
}
@section GoToTop{
  @if (!isMobile || (isMobile && showGoToTop))
  {
    <div id="goToTop"></div>
  }
}
@if (isMobile && showFingerBackground)
{
  <div class="finger-bg"></div>
}
<div class="responsive-nav-wrapper-parent">
  @if (isMobile)
  {
    if (applyBack)
    {
      <div id="mobile-top-panel-wrapper" class="top-panel-wrapper">
        <div class="back-button" onclick="goBack()">
          <span>Back</span>
          @if (!string.IsNullOrWhiteSpace(backIconClass))
          {
            <span class="@backIconClass">Home</span>
          }
        </div>
        <script>
          function goBack() {
            @if (showLeaveConfirmation)
            {
              @:confirm("Are you sure you want to leave this page?");
            }

           @if (string.IsNullOrWhiteSpace(backAction))
           {
             @:window.history.go(-1);
           }
           else
           {
             @:window.location.href = '@backAction';
           }
           }
        </script>
        <div class="product-name">
          @RenderSection("MobileHeader", false)
        </div>
        @*<div class="shopping-cart-link">
            <a href="@Url.RouteUrl("ShoppingCart")">@T("ShoppingCart")</a>
          </div>*@
      </div>
    }
    else
    {
      <div class="top-menu-wrapper">
        <div class="menu-title">
          <span>@T("SevenSpikes.Themes.Common.MenuTitle")</span>
        </div>
        <div class="logo">
        </div>
        <div class="shopping-cart-link">
          <a href="@Url.RouteUrl("ShoppingCart")">@T("ShoppingCart")</a>
        </div>
      </div>
    }
  }
  else
  {
    <span style="display:none">
      @RenderSection("ProductName", false)
    </span>
    <div class="responsive-nav-wrapper">
      <div class="menu-title">
        <span>@T("SevenSpikes.Themes.Common.MenuTitle")</span>
      </div>
      <div class="search-wrap">
        <span>@T("Search")</span>
      </div>
      <div class="to-wishlist">
        <a href="@Url.RouteUrl("Wishlist")" class="ico-wishlist">
          <span class="wishlist-label">@T("Wishlist")</span>
        </a>
      </div>
      <div class="shopping-cart-link">
        <a href="@Url.RouteUrl("ShoppingCart")">@T("ShoppingCart")</a>
      </div>
      <div class="personal-button" id="header-links-opener">
        <span>@T("SevenSpikes.Themes.Common.Personal")</span>
      </div>
    </div>
  }
</div>

@await Html.PartialAsync("_Header")
@await Component.InvokeAsync("HeaderLinks")

@if (isHomePage)
{
  @await Component.InvokeAsync("Widget", new { widgetZone = "home_page_main_slider" })
}

@await Component.InvokeAsync("Widget", new { widgetZone = "ajax_filters_poppy" })

<div class="master-wrapper-page">

  @if (IsSectionDefined("blogNavigationSection"))
  {
    @RenderSection("blogNavigationSection");
  }

  <script type="text/javascript" asp-location="Footer">
    AjaxCart.init(false, '.header-links .cart-qty', '.header-links .wishlist-qty', '#flyout-cart');
  </script>
  <div class="overlayOffCanvas"></div>
  <div class="header-menu">
    <div class="close-menu">
      <span>@T("SevenSpikes.Themes.Common.CloseMenu")</span>
    </div>
    @{
      var menuHtml = await Component.InvokeAsync("Widget", new { widgetZone = "theme_header_menu" });
    }
    @if (!String.IsNullOrEmpty(menuHtml.ToHtmlString()))
    {
      @menuHtml
    }
    else
    {
      @await Component.InvokeAsync("TopMenu")
    }
  </div>
  <div class="master-wrapper-content">
    @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.ContentBefore })

    @if (IsSectionDefined("Breadcrumb"))
    {
      @RenderSection("Breadcrumb")
    }
    <div class="master-column-wrapper">
      @RenderBody()
    </div>
  </div>
  @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.ContentAfter })
  @if (isHomePage)
  {
    @await Component.InvokeAsync("Widget", new { widgetZone = "home_page_before_poll" })
    @await Component.InvokeAsync("HomepagePolls")
  }
  @await Component.InvokeAsync("Footer")
</div>
@await Component.InvokeAsync("EuCookieLaw")
@await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.BodyEndHtmlTagBefore })
