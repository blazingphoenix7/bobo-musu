@{
  Layout = "_Root";
}
@if (IsSectionDefined("Breadcrumb"))
{
  @section Breadcrumb {
    @RenderSection("Breadcrumb")
  }
}

@if (IsSectionDefined("blogNavigation"))
{
  @section blogNavigationSection {
    @RenderSection("blogNavigation")
  }
}
@if (IsSectionDefined("ProductName"))
{
  @section ProductName {
    @RenderSection("ProductName", false)
  }
}
<div class="center-1">
  @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.MainColumnBefore })
  @RenderBody()
  @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.MainColumnAfter })
</div>
