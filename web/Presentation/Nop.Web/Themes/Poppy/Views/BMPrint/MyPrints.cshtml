@model MyPrintListModel
@using System.Text.Encodings.Web
@using Nop.Core
@using Nop.Web.Models.BM
@using Nop.Core.Domain.Common

@inject Nop.Core.IWebHelper webHelper
@inject CommonSettings commonSettings

@{
  Layout = "_CustomColumns";

  //title
  Html.AddTitleParts("Your Print Vault");
  Html.AppendPageCssClassParts("print-vault");
  //page class
  Html.AppendPageCssClassParts("html-account-page");
  Html.AppendPageCssClassParts("html-address-list-page");
  //var breadcrumbDelimiter = commonSettings.BreadcrumbDelimiter;

}
<style>
</style>
<div class="page account-page address-list-page my-print-panel from-panel">
  <div class="page-title">
    <h1>My Prints</h1>
  </div>

  @*<div class="breadcrumb">
      <ul itemscope itemtype="http://schema.org/BreadcrumbList">
        <li>
          <a href="@Url.RouteUrl("HomePage")" title="@T("Categories.Breadcrumb.Top")">@T("Categories.Breadcrumb.Top")</a>
          <span class="delimiter">@breadcrumbDelimiter</span>
        </li>
        <li itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
          <strong class="current-item" itemprop="name">Print vault</strong>
        </li>
      </ul>
    </div>*@
  <div class="page-body" >

    @await Component.InvokeAsync("BMPrintVaultNavigation", new { selectedTabId = PrintVaultNavigationEnum.MyPrints })

    @if (!Model.Prints.Any())
    {
      <div class="no-data">
        No prints available, kindly take some!
      </div>
    }
    <div class="col-md-12" style="padding:20px;">
      @foreach (var item in Model.Prints)
      {
        <div class="col-xs-6 col-md-3 col-sm-4 print-box">
          <div class="thumbnail">
            <a class="btn-delete-print close" href="javascript:void(0);" data-print-id="@item.Id">
              <i class="glyphicon glyphicon glyphicon-trash"></i>
            </a>
            <img src="@item.ThumbnailPath" class="my-print-icon" />
            <div class="caption text-center">
              <h5>@item.Name</h5>
            </div>
          </div>
        </div>
      }
    </div>
    @*<div class="add-button">
        <input type="button" class="button-1 add-address-button" onclick="location.href='@Url.RouteUrl("CustomerAddressAdd")'" value="@T("Common.AddNew")" />
      </div>*@
  </div>
  @*<div class="row panel-footer element-fixed">
      <div class="col-xs-12 col-md-12 col-sm-12 text-center">
        <button type="button" class="btn btn-primary-custom btn-sm btn-add-new-print">Take a Print</button>
        <a href="@Url.RouteUrl("BMSharedPrints")" class="btn btn-primary-custom btn-sm">Shared Prints</a>
      </div>
    </div>*@

  @*<div class="row panel-footer element-fixed">
      <div class="col-xs-12 col-md-12 col-sm-12 text-center">
        <button type="button" class="btn btn-primary-custom btn-sm btn-add-new-print">Take a Print</button>
        <a href="@Url.RouteUrl("BMSharedPrints")" class="btn btn-primary-custom btn-sm">Shared Prints</a>
      </div>
    </div>*@
</div>

<form asp-route="BMPrint_Delete" class="form-horizontal" method="post">
  <div id="delete-print-modal" class="modal fade" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
          <h4 class="modal-title">Confirmation</h4>
        </div>
        <div class="modal-body">
          <p>Are you sure delete this item?</p>
        </div>
        <div class="modal-footer">
          <input type="hidden" id="deletePrintId" name="printId" />
          <button type="submit" class="btn btn-primary-custom">YES</button>
          <button type="button" class="btn btn-default" data-dismiss="modal">NO</button>
        </div>
      </div>
    </div>
  </div>
</form>

<script asp-location="Footer">
  $('.btn-add-new-print').click(function () {
    bm.addNewPrint();
  });
  $('.btn-delete-print').click(function () {
    var printId = $(this).data('print-id');
    $('#deletePrintId').val(printId);
    $('#delete-print-modal').modal();
  });
</script>